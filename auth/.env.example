# URL base de la app (usada para construir las redirect URIs de cada nube)
BASE_URL=http://localhost:8000

# Clave para firmar la cookie de sesion (genera una con: openssl rand -hex 32)
SESSION_SECRET_KEY=change-me

# --- AWS Cognito ---
# Region del User Pool, ej: eu-west-1
AWS_COGNITO_REGION=
# ID del User Pool, ej: eu-west-1_XXXXXXXXX
AWS_COGNITO_USER_POOL_ID=
# App client (sin secreto habilitado si usas PKCE, o con secreto)
AWS_COGNITO_CLIENT_ID=
AWS_COGNITO_CLIENT_SECRET=
# Dominio del Hosted UI, ej: https://tu-dominio.auth.eu-west-1.amazoncognito.com
AWS_COGNITO_DOMAIN=

# --- Azure AD (Microsoft Entra ID) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Google (OAuth 2.0 / GCP) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
